// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Characterization snapshots — pre-flag UI > <App /> empty hero <main> matches snapshot 1`] = `"<p class="text-fg-muted text-sm">Use WhatsApp to chat with the bot. Use <kbd>/</kbd> commands below to manage settings.</p>"`;

exports[`Characterization snapshots — pre-flag UI > <StatusPopover /> matches snapshot 1`] = `"<div role="dialog" aria-label="Readiness summary" class="absolute left-0 top-full z-40 mt-2 w-72 rounded-card border border-border bg-bg-card p-3 shadow-sm"><ul class="divide-y divide-border"><li class="flex items-center justify-between py-2 text-xs"><span class="text-fg-muted">Model</span><span class="inline-flex items-center gap-2"><span aria-hidden="true" class="relative inline-flex size-2 items-center justify-center"><span class="absolute inline-flex size-2 rounded-full bg-fg-muted"></span><svg aria-hidden="true" viewBox="0 0 8 8" class="absolute size-2 text-bg-app" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4 L2 4"></path><path d="M4 4 L4 4"></path><path d="M6 4 L6 4"></path></svg></span><span>Checking…</span></span></li><li class="flex items-center justify-between py-2 text-xs"><span class="text-fg-muted">wabot</span><span class="inline-flex items-center gap-2"><span aria-hidden="true" class="relative inline-flex size-2 items-center justify-center"><span class="absolute inline-flex size-2 rounded-full bg-fg-muted"></span><svg aria-hidden="true" viewBox="0 0 8 8" class="absolute size-2 text-bg-app" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4 L2 4"></path><path d="M4 4 L4 4"></path><path d="M6 4 L6 4"></path></svg></span><span>Checking…</span></span></li><li class="flex items-center justify-between py-2 text-xs"><span class="text-fg-muted">Send policy</span><span class="inline-flex items-center gap-2"><span aria-hidden="true" class="relative inline-flex size-2 items-center justify-center"><span class="absolute inline-flex size-2 rounded-full bg-fg-muted"></span><svg aria-hidden="true" viewBox="0 0 8 8" class="absolute size-2 text-bg-app" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4 L2 4"></path><path d="M4 4 L4 4"></path><path d="M6 4 L6 4"></path></svg></span><span>Checking…</span></span></li><li class="flex items-center justify-between py-2 text-xs"><span class="text-fg-muted">Memory</span><span class="inline-flex items-center gap-2"><span aria-hidden="true" class="relative inline-flex size-2 items-center justify-center"><span class="absolute inline-flex size-2 rounded-full bg-fg-muted"></span><svg aria-hidden="true" viewBox="0 0 8 8" class="absolute size-2 text-bg-app" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4 L2 4"></path><path d="M4 4 L4 4"></path><path d="M6 4 L6 4"></path></svg></span><span>Checking…</span></span></li></ul></div>"`;

exports[`Characterization snapshots — pre-flag UI > <TopBar /> matches snapshot 1`] = `"<header class="sticky top-0 z-30 flex h-14 items-center justify-between border-b border-border bg-bg-app/80 px-4 backdrop-blur"><div class="relative"><button class="inline-flex items-center gap-2 font-medium tracking-tight" aria-haspopup="dialog" aria-expanded="false"><span>wabot-agent</span><span aria-hidden="true" class="relative inline-flex size-2 items-center justify-center"><span class="absolute inline-flex size-2 rounded-full bg-fg-muted"></span><svg aria-hidden="true" viewBox="0 0 8 8" class="absolute size-2 text-bg-app" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4 L2 4"></path><path d="M4 4 L4 4"></path><path d="M6 4 L6 4"></path></svg></span></button></div><nav class="flex items-center gap-1" aria-label="Workspace"><button aria-label="Knowledge base" title="Knowledge base" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open size-4"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg></button><button aria-label="Agents" title="Agents" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bot size-4"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg></button><button aria-label="Tools" title="Tools" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wrench size-4"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg></button><button aria-label="Integrations" title="Integrations" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plug size-4"><path d="M12 22v-5"></path><path d="M9 8V2"></path><path d="M15 8V2"></path><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"></path></svg></button><button aria-label="Overview dashboard" title="Overview dashboard" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chart-column size-4"><path d="M3 3v16a2 2 0 0 0 2 2h16"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg></button><a href="/pair" target="_blank" rel="noopener" aria-label="WhatsApp pairing" title="WhatsApp pairing" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-smartphone size-4"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg></a><button aria-label="Runs history" title="Runs history" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock size-4"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></button><button aria-label="WhatsApp groups" title="WhatsApp groups" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users size-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></button><button aria-label="Settings" title="Settings" class="grid size-11 place-items-center rounded-pill text-fg-muted transition hover:bg-bg-card hover:text-fg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings size-4"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-