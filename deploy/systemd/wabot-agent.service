[Unit]
Description=wabot-agent
After=network-online.target wabot.service
Wants=network-online.target

[Service]
Type=simple
User=wabotagent
Group=wabotagent
WorkingDirectory=/opt/wabot-agent
EnvironmentFile=/opt/wabot-agent/.env
Environment=PYTHONUNBUFFERED=1
Environment=UV_CACHE_DIR=/opt/wabot-agent/.uv-cache
Environment=HF_HOME=/opt/wabot-agent/data/hf-cache
Environment=HF_HUB_CACHE=/opt/wabot-agent/data/hf-cache/hub
Environment=XDG_CACHE_HOME=/opt/wabot-agent/data/cache
ExecStart=/usr/local/bin/uv run --frozen --no-sync python main.py
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/wabot-agent/data /opt/wabot-agent/.uv-cache

[Install]
WantedBy=multi-user.target
