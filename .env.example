# Copy to .env on the VPS. Never commit real values.

# Model provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/TeddyJubu/wabot-agent
OPENROUTER_APP_TITLE=wabot-agent

# Agent service
WABOT_AGENT_HOST=127.0.0.1
WABOT_AGENT_PORT=8787
WABOT_AGENT_ENV=local
WABOT_AGENT_OFFLINE_MODE=false
WABOT_AGENT_DATA_DIR=./data
WABOT_AGENT_DB_PATH=./data/wabot-agent.db
WABOT_AGENT_LOG_PATH=./data/events.jsonl
WABOT_AGENT_MEDIA_DIR=./data/media
WABOT_AGENT_MCP_CONFIG=./configs/mcp.example.json
WABOT_AGENT_OPERATOR_TOKEN=

# Fail-closed by default. Use allowlist on production, not allow_all, unless you
# deliberately want an unattended sender.
WABOT_AGENT_SEND_POLICY=dry_run
WABOT_AGENT_ALLOWED_RECIPIENTS=

# wabot daemon
WABOT_ENDPOINT=http://127.0.0.1:7777
WABOT_TOKEN=
WABOT_INBOUND_TOKEN=
