# Copy to .env on the VPS. Never commit real values.

# Model provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/TeddyJubu/vignesh
OPENROUTER_APP_TITLE=Vignesh WhatsApp Agent

# Agent service
VIGNESH_HOST=127.0.0.1
VIGNESH_PORT=8787
VIGNESH_ENV=local
VIGNESH_OFFLINE_MODE=false
VIGNESH_DATA_DIR=./data
VIGNESH_DB_PATH=./data/vignesh-agent.db
VIGNESH_LOG_PATH=./data/events.jsonl
VIGNESH_MEDIA_DIR=./data/media
VIGNESH_MCP_CONFIG=./configs/mcp.example.json
VIGNESH_OPERATOR_TOKEN=

# Fail-closed by default. Use allowlist on production, not allow_all, unless you
# deliberately want an unattended sender.
VIGNESH_SEND_POLICY=dry_run
VIGNESH_ALLOWED_RECIPIENTS=

# wabot daemon
WABOT_ENDPOINT=http://127.0.0.1:7777
WABOT_TOKEN=
WABOT_INBOUND_TOKEN=
