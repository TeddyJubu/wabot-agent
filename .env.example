# Copy to .env on the VPS. Never commit real values.

# LLM provider: openrouter | ollama | ollama_cloud
WABOT_AGENT_MODEL_PROVIDER=openrouter

# OpenRouter (hosted models, credits)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/TeddyJubu/wabot-agent
OPENROUTER_APP_TITLE=wabot-agent

# Ollama local daemon (OpenAI-compatible at /v1). Cloud models via :cloud tag after ollama pull.
# WABOT_AGENT_MODEL_PROVIDER=ollama
# OLLAMA_MODEL=minimax-m2.7:cloud
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=

# Ollama Cloud direct API (e.g. gemma4:31b-cloud → gemma4:31b on API). Key: ollama.com/settings/keys
# WABOT_AGENT_MODEL_PROVIDER=ollama_cloud
# OLLAMA_MODEL=gemma4:31b-cloud
# OLLAMA_API_KEY=
# OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# Agent service
WABOT_AGENT_HOST=127.0.0.1
WABOT_AGENT_PORT=8787
WABOT_AGENT_ENV=local
WABOT_AGENT_OFFLINE_MODE=false
WABOT_AGENT_DATA_DIR=./data
WABOT_AGENT_DB_PATH=./data/wabot-agent.db
WABOT_AGENT_LOG_PATH=./data/events.jsonl
WABOT_AGENT_MEDIA_DIR=./data/media
WABOT_AGENT_MCP_CONFIG=./configs/mcp.example.json
# Composio Connect MCP (https://docs.composio.dev/docs/composio-connect) — see docs/composio-mcp-setup.md
# COMPOSIO_API_KEY=
# WABOT_AGENT_MCP_CONFIG=./configs/mcp.composio.json
WABOT_AGENT_OPERATOR_TOKEN=
# Optional short password for https://…/login (falls back to operator token).
WABOT_AGENT_DASHBOARD_PASSWORD=

# Send policy: allow_all | owner | allowlist | dry_run (default: allow_all)
# allow_all: agent may message any recipient (use with care on production VPS).
# owner: dashboard + owner_numbers may message anyone; others reply-only in-thread.
WABOT_AGENT_SEND_POLICY=allow_all
WABOT_AGENT_OWNER_NUMBERS=
WABOT_AGENT_ALLOWED_RECIPIENTS=
# Deliver agent final_output to inbound senders via WhatsApp (1:1 and groups).
WABOT_AGENT_AUTO_REPLY=true
# Group chat behavior (still gated by send_policy / allowlist).
WABOT_AGENT_GROUP_AUTO_REPLY=true
WABOT_AGENT_GROUP_TYPING=true
WABOT_AGENT_GROUP_PROCESS_MEDIA=true
# Show WhatsApp typing while the agent processes inbound messages.
WABOT_AGENT_TYPING_INDICATOR=true
WABOT_AGENT_TYPING_REFRESH_SECONDS=5
# Scheduled WhatsApp reminders (background loop in wabot-agent lifespan).
WABOT_AGENT_REMINDERS_ENABLED=true
WABOT_AGENT_REMINDER_POLL_INTERVAL_SEC=30
WABOT_AGENT_REMINDER_MAX_PENDING_PER_CONTACT=50
# Outbound outreach follow-up: notify owner when a tracked contact replies (days until expiry).
WABOT_AGENT_OUTBOUND_TASK_EXPIRY_DAYS=7
# Context management — bounded session history, token budget, and SQLite retention.
WABOT_AGENT_SESSION_HISTORY_LIMIT=48
WABOT_AGENT_SESSION_MAX_HISTORY_TOKENS=20000
WABOT_AGENT_SESSION_DB_KEEP_ITEMS=80
WABOT_AGENT_PROMPT_MAX_CHARS=32000
WABOT_AGENT_CONTEXT_MAX_INBOUND_ROWS=10000
WABOT_AGENT_CONTEXT_MAX_RUNS=5000
WABOT_AGENT_CONTEXT_MAX_TOOL_EVENTS=20000
WABOT_AGENT_CONTEXT_PRUNE_EVERY_RUNS=25
# LLM summary of dropped/pruned thread history (stored per session_id in SQLite).
WABOT_AGENT_SESSION_SUMMARY_ENABLED=true
WABOT_AGENT_SESSION_SUMMARY_MIN_DROPPED_TOKENS=800
WABOT_AGENT_SESSION_SUMMARY_MAX_CHARS=2500
WABOT_AGENT_SESSION_SUMMARY_MAX_OUTPUT_TOKENS=512
# Optional cheaper model for summaries only (defaults to active chat model).
# WABOT_AGENT_SESSION_SUMMARY_MODEL=openai/gpt-4.1-mini
# Attach inbound photos to the vision model (gemma4, qwen3-vl, gpt-4o, etc.).
WABOT_AGENT_VISION_ATTACH_IMAGES=true
# Download and extract inbound files on the VPS (PDF, text, zip listings, etc.).
WABOT_AGENT_FILE_PROCESS_INBOUND=true
WABOT_AGENT_FILE_EXCERPT_LIMIT=12000
WABOT_AGENT_FILE_MAX_PROCESS_BYTES=20971520
WABOT_AGENT_FILE_USE_SYSTEM_TOOLS=true
WABOT_AGENT_FILE_OCR_ENABLED=true
WABOT_AGENT_FILE_OCR_LANGUAGE=eng
WABOT_AGENT_FILE_PDF_OCR_MAX_PAGES=10
# Speech-to-text: tiny for inbound strangers; base (or small) for owner_numbers + dashboard.
WABOT_AGENT_WHISPER_MODEL=tiny
# small is much more accurate than base on WhatsApp voice notes (needs ~1–2GB RAM).
WABOT_AGENT_WHISPER_MODEL_OWNER=small
WABOT_AGENT_WHISPER_MAX_SECONDS=90
WABOT_AGENT_WHISPER_COMPUTE_TYPE=int8
WABOT_AGENT_WHISPER_BEAM_SIZE=3
WABOT_AGENT_WHISPER_BEAM_SIZE_OWNER=5
# Set to en (or bn, zh, etc.) if auto-detect is wrong; leave empty for auto.
WABOT_AGENT_WHISPER_LANGUAGE=
# Optional hint for names/terms: WABOT_AGENT_WHISPER_INITIAL_PROMPT=WhatsApp voice message
WABOT_AGENT_WHISPER_VAD_FILTER=true
# Retry wabot media/download when cache is not ready yet (inbound webhook race).
WABOT_AGENT_MEDIA_DOWNLOAD_ATTEMPTS=5
WABOT_AGENT_MEDIA_DOWNLOAD_RETRY_SECONDS=0.5
# Whisper/Hugging Face cache (set by systemd on VPS; under data/ for ProtectHome)
# HF_HOME=./data/hf-cache
# HF_HUB_CACHE=./data/hf-cache/hub
# XDG_CACHE_HOME=./data/cache

# Web search + download (DuckDuckGo HTML + httpx; SSRF-safe public URLs only)
WABOT_AGENT_WEB_FETCH_ENABLED=true
WABOT_AGENT_WEB_SEARCH_ENABLED=true
WABOT_AGENT_WEB_FETCH_MAX_BYTES=15728640
WABOT_AGENT_WEB_FETCH_TIMEOUT_SEC=45
WABOT_AGENT_WEB_SEARCH_MAX_RESULTS=8

# Firecrawl web-agent sidecar (https://github.com/firecrawl/web-agent) — deep scraping / lead lists
# See docs/web-agent-setup.md. Express template on loopback :3000 by default.
# WABOT_AGENT_WEB_AGENT_ENABLED=true
# WABOT_AGENT_WEB_AGENT_URL=http://127.0.0.1:3000
# WABOT_AGENT_WEB_AGENT_TIMEOUT_SEC=7200
# WABOT_AGENT_WEB_AGENT_MAX_CONCURRENT=1
# WABOT_AGENT_WEB_AGENT_MAX_PENDING_PER_CONTACT=3
# WABOT_AGENT_WEB_AGENT_OWNER_ONLY=true
# WABOT_AGENT_WEB_AGENT_NOTIFY_ON_COMPLETE=true

# Mem0 long-term semantic memory (https://github.com/mem0ai/mem0) — see docs/mem0-setup.md
# WABOT_AGENT_MEM0_ENABLED=true
# WABOT_AGENT_MEM0_PATH=./data/mem0_qdrant
# WABOT_AGENT_MEM0_TOP_K=5
# WABOT_AGENT_MEM0_AUTO_CAPTURE=true
# WABOT_AGENT_MEM0_INJECT_ON_RUN=true
# WABOT_AGENT_MEM0_USE_PLATFORM=false
# MEM0_API_KEY=

# wabot daemon
WABOT_ENDPOINT=http://127.0.0.1:7777
WABOT_TOKEN=
WABOT_TOKEN_FILE=~/.config/wabot/token
WABOT_INBOUND_TOKEN=
# wabot webhooks (loopback only — never expose via Cloudflare Tunnel)
# WABOT_RECEIPT_URL=http://127.0.0.1:8787/whatsapp/receipt
# WABOT_PRESENCE_URL=http://127.0.0.1:8787/whatsapp/presence
# WABOT_HISTORY_SYNC_URL=http://127.0.0.1:8787/whatsapp/history-sync
# WABOT_HISTORY_URL=http://127.0.0.1:8787/whatsapp/history
# Path to wabot install on the VPS (required for /pair "New QR"). Example: /opt/wabot
WABOT_AGENT_WABOT_HOME=
# Optional; default uses WABOT_AGENT_WABOT_HOME restart. On systemd VPS, leave empty.
WABOT_AGENT_WABOT_RESTART_COMMAND=
# Optional shell command instead of WABOT_AGENT_WABOT_HOME
WABOT_AGENT_WABOT_RESTART_COMMAND=

# --- Public access via Cloudflare Tunnel + Cloudflare Access (optional) ---
# When you want anyone with browser access to a public URL to be able to
# pair WhatsApp from their phone, run scripts/setup-cloudflared.sh on the
# VPS, then create a Cloudflare Access application for the hostname and
# set the three values below. Leaving them unset (or REQUIRED=false)
# preserves today's operator-token-only behaviour, suitable for local dev.
WABOT_AGENT_CF_ACCESS_TEAM_DOMAIN=
WABOT_AGENT_CF_ACCESS_AUD=
WABOT_AGENT_CF_ACCESS_REQUIRED=false
