.venv/
build/
dist/*.tar.gz
dist/*.sha256
*.egg-info/
__pycache__/
.pytest_cache/
.ruff_cache/
.playwright-mcp/
.mypy_cache/
# Ignore everything in .claude/ EXCEPT the project-scoped subagent
# definitions, which are part of the repo so anyone cloning picks them up.
# (Per gitignore rules, you can't re-include children of an ignored parent —
# so we ignore .claude/* and then re-include the agents subtree explicitly.)
.claude/*
!.claude/agents/
.DS_Store

# Runtime state and secrets
.env
.env.*
!.env.example
data/*.db
data/*.db-*
data/*.jsonl
data/*.log
data/*.json
# Phase 4: curated registry JSONs shipped with the repo — exempt from the
# broad `data/*.json` runtime-state ignore above.
!data/skills_registry.json
!data/mcp_registry.json
data/operator-token.txt
evals/results/*
!evals/results/.gitkeep

# wabot identity/session material must never be committed.
store.db
wabot.env
sends.log

# Frontend (web/) — built into static/ via scripts/build-web.sh
web/node_modules/
web/dist/
web/.vite/

data/media/
data/knowledge/

# Mem0 / Qdrant / Composio / Codex runtime state — never commit
data/cache/
data/codex/
data/composio/
data/hf-cache/
data/mem0/
data/mem0_qdrant/
